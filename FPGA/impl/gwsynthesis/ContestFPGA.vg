module watchdog_top (
  clk,
  s1_wdi,
  s2_en,
  rx,
  tx,
  led_d3_wdo,
  led_d4_enout,
  tms_pad_i,
  tck_pad_i,
  tdi_pad_i,
  tdo_pad_o
)
;
input clk;
input s1_wdi;
input s2_en;
input rx;
output tx;
output led_d3_wdo;
output led_d4_enout;
input tms_pad_i;
input tck_pad_i;
input tdi_pad_i;
output tdo_pad_o;
wire clk_d;
wire s1_wdi_d;
wire s2_en_d;
wire rx_d;
wire btn_en_high;
wire Q1;
wire Q2;
wire rx_done_Z;
wire uart_core_kick_n;
wire uart_core_en;
wire valid_frame_pulse_Z;
wire tx_start_Z;
wire tx_busy_Z;
wire tx_d;
wire n519_16;
wire n520_11;
wire n271_4;
wire n519_22;
wire n519_23;
wire n519_24;
wire [7:0] rx_data_Z;
wire [31:0] twd_ms_Z;
wire [31:0] trst_ms_Z;
wire [15:0] arm_delay_us_Z;
wire [7:0] valid_cmd_Z;
wire [7:0] valid_addr_Z;
wire [7:0] tx_data_Z;
wire [1:0] state;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF s1_wdi_ibuf (
    .O(s1_wdi_d),
    .I(s1_wdi) 
);
  IBUF s2_en_ibuf (
    .O(s2_en_d),
    .I(s2_en) 
);
  IBUF rx_ibuf (
    .O(rx_d),
    .I(rx) 
);
  OBUF tx_obuf (
    .O(tx),
    .I(tx_d) 
);
  OBUF led_d3_wdo_obuf (
    .O(led_d3_wdo),
    .I(n519_22) 
);
  OBUF led_d4_enout_obuf (
    .O(led_d4_enout),
    .I(state[1]) 
);
  gw_gao gw_gao_inst_0 (
    .tms_pad_i(tms_pad_i),
    .tck_pad_i(tck_pad_i),
    .tdi_pad_i(tdi_pad_i),
    .clk_d(clk_d),
    .s2_en_d(s2_en_d),
    .n519_24(n519_24),
    .n519_23(n519_23),
    .n520_11(n520_11),
    .n519_16(n519_16),
    .s1_wdi_d(s1_wdi_d),
    .n519_22(n519_22),
    .state(state[1]),
    .tdo_pad_o(tdo_pad_o)
);
  debounce_button deb_en (
    .clk_d(clk_d),
    .s2_en_d(s2_en_d),
    .btn_en_high(btn_en_high)
);
  debounce_button_0 deb_wdi (
    .clk_d(clk_d),
    .s1_wdi_d(s1_wdi_d),
    .Q1(Q1),
    .Q2(Q2)
);
  uart_rx u_rx (
    .clk_d(clk_d),
    .rx_d(rx_d),
    .rx_done_Z(rx_done_Z),
    .rx_data_Z(rx_data_Z[7:0])
);
  frame_parser u_parser (
    .clk_d(clk_d),
    .rx_done_Z(rx_done_Z),
    .rx_data_Z(rx_data_Z[7:0]),
    .uart_core_kick_n(uart_core_kick_n),
    .uart_core_en(uart_core_en),
    .valid_frame_pulse_Z(valid_frame_pulse_Z),
    .twd_ms_Z(twd_ms_Z[31:0]),
    .trst_ms_Z(trst_ms_Z[31:0]),
    .arm_delay_us_Z(arm_delay_us_Z[15:0]),
    .valid_cmd_Z(valid_cmd_Z[7:0]),
    .valid_addr_Z(valid_addr_Z[7:0])
);
  uart_frame_responder u_responder (
    .clk_d(clk_d),
    .n519_16(n519_16),
    .n271_4(n271_4),
    .valid_frame_pulse_Z(valid_frame_pulse_Z),
    .tx_busy_Z(tx_busy_Z),
    .state(state[1:0]),
    .trst_ms_Z(trst_ms_Z[31:0]),
    .twd_ms_Z(twd_ms_Z[31:0]),
    .valid_cmd_Z(valid_cmd_Z[7:0]),
    .valid_addr_Z(valid_addr_Z[7:0]),
    .arm_delay_us_Z(arm_delay_us_Z[15:0]),
    .tx_start_Z(tx_start_Z),
    .tx_data_Z(tx_data_Z[7:0])
);
  uart_tx u_tx (
    .clk_d(clk_d),
    .tx_start_Z(tx_start_Z),
    .tx_data_Z(tx_data_Z[7:0]),
    .tx_busy_Z(tx_busy_Z),
    .tx_d(tx_d)
);
  watchdog_core wd_core (
    .clk_d(clk_d),
    .btn_en_high(btn_en_high),
    .uart_core_en(uart_core_en),
    .Q2(Q2),
    .Q1(Q1),
    .uart_core_kick_n(uart_core_kick_n),
    .twd_ms_Z(twd_ms_Z[31:0]),
    .trst_ms_Z(trst_ms_Z[31:0]),
    .arm_delay_us_Z(arm_delay_us_Z[15:0]),
    .n519_16(n519_16),
    .n520_11(n520_11),
    .n271_4(n271_4),
    .n519_22(n519_22),
    .n519_23(n519_23),
    .n519_24(n519_24),
    .state(state[1:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* watchdog_top */
